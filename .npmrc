# ── npm supply-chain hardening (balanced) ──────────────────────────────
# Use `npm ci` (not `npm install`) everywhere — it installs EXACTLY the
# lockfile and fails if package.json and package-lock.json disagree, so a
# tampered/typosquatted dependency can't sneak in via a loosened range.

# Pin exact versions when adding new deps (no ^ or ~ drift)
save-exact=true

# Enforce package.json "engines" — blocks installs on an unexpected runtime
engine-strict=true

# Surface vulnerabilities on every install
audit=true

# No funding spam in logs
fund=false

# NOTE: install scripts stay ENABLED — better-sqlite3 and sharp need their
# native postinstall builds. Protection here is the pinned lockfile + `npm ci`.
# For maximum lockdown set ignore-scripts=true and rebuild those two:
#   npm rebuild better-sqlite3 sharp
