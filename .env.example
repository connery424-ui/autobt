# AutoBot Trading — Environment Variables
# Copy this file to .env and fill in your actual values
# Generate secrets: openssl rand -hex 32

# === REQUIRED — App will not start without these ===
HELIUS_API_KEY=your_helius_api_key_here          # https://helius.dev (free tier works)
JWT_SECRET=replace_with_64_char_random_string     # openssl rand -hex 32
WALLET_ENCRYPTION_KEY=replace_with_32_char_string # openssl rand -hex 16

# === SERVER PORT ===
PORT=3001

# === RPC POOL (optional extras — server round-robins) ===
# HELIUS_API_KEY_2=your_second_helius_key
# HELIUS_API_KEY_3=your_third_helius_key
# RPC_URL_1=https://your-quicknode-endpoint.quiknode.pro/YOUR_KEY/

# === GEYSER gRPC (optional — for real-time token detection) ===
GEYSER_GRPC_ENDPOINT=grpc.tavahin.com:443
GEYSER_AUTH_TOKEN=your_geyser_auth_token_here

# === OPTIONAL APIs ===
BIRDEYE_API_KEY=your_birdeye_api_key_here
JITO_TIP_AMOUNT=50000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# === PROGRAM IDs (Reference - do not modify) ===
# RAYDIUM_AMM_PROGRAM=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
# RAYDIUM_CLMM_PROGRAM=CAMMCzo5YL8w4VFF8KVHrK22GGUsp5VTaW7grrKgrWqK
# PUMPFUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
# LAUNCHLAB_PROGRAM=LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo

# === REMOVED - No longer needed (local SQLite replaces Supabase) ===
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# DATABASE_URL=
# DIRECT_URL=
# PINGER_SECRET_KEY=
