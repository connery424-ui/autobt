{
  "name": "autobot-trading",
  "private": true,
  "version": "2.8.11",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.frontend.config.ts",
    "build": "vite build --config vite.frontend.config.ts",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=server-build/server.mjs --format=esm --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url); const __filename = require('url').fileURLToPath(import.meta.url); const __dirname = require('path').dirname(__filename);\" --external:@prisma/client --external:fsevents --external:better-sqlite3 --external:sharp",
    "build:app": "npm run build && npm run build:server",
    "start": "tsx server.ts",
    "start:prod": "NODE_ENV=production ELECTRON_APP=true node server-build/server.mjs",
    "tsc": "tsc --skipLibCheck",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview --config vite.frontend.config.ts",
    "server": "NODE_OPTIONS=--max-old-space-size=768 tsx server.ts",
    "server:dev": "tsx --watch server.ts",
    "test": "vitest run --workspace",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "lint:theme": "bash -c '! grep -rn \"bg-gray-[89]00\" src/pages src/components --include=\"*.tsx\" || (echo \"\u274c hardcoded gray theme classes found (audit \u00a73.4)\" && exit 1)'"
  },
  "dependencies": {
    "@jup-ag/api": "^6.0.44",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.3",
