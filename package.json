    "lru-cache": "^11.1.0",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.1",
    "prisma": "^5.22.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.22.3",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.0.2",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.6"
