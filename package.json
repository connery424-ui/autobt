    "@solana/web3.js": "^1.98.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ws": "^8.18.1",
    "axios": "^1.10.0",
    "bs58": "^6.0.0",
    "chart.js": "^4.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-fetch": "^4.1.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.1.0",
    "jito-js-rpc": "^0.2.2",
